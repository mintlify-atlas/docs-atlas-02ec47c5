  "keyFeatures": [
    "REST API wrapper around Telethon for Telegram MTProto integration",
    "Two-step sign-in flow (phone code + confirmation)",
    "Session persistence via AWS S3 (StringSession serialization)",
    "Channel management: list, join, and leave Telegram channels",
    "Time-range message retrieval from all subscribed channels",
    "FakeClient for development/testing without a real Telegram account",
    "Sentry integration for error monitoring",
    "Docker-based deployment with multi-stage builds"
  ],
  "publicApiSurface": [
    "GET /is_user_authorized",
    "POST /sign_in",
    "GET /channels",
    "POST /channels",
    "DELETE /channels",
    "GET /messages",
